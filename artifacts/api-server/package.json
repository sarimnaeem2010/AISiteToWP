    "ip-address": "^10.1.0",
    "jsdom": "^29.0.2",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "pino": "^9",
    "pino-http": "^10",
    "undici": "^8.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
